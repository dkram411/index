<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Core Accounting Challenge</title>
<style>
:root {
  --bg: #f6f7fb;
  --paper: #ffffff;
  --primary: #143d59;
  --primary-light: #edf4fa;
  --accent: #2e7d32;
  --accent-light: #edf8ef;
  --danger: #b42318;
  --danger-light: #fff1f1;
  --text: #1f2937;
  --muted: #667085;
  --border: #d9e2ec;
  --shadow: rgba(16,24,40,0.08);
}
*{box-sizing:border-box}
body{
  margin:0;
  font-family: Inter, Arial, sans-serif;
  background:var(--bg);
  color:var(--text);
}
.container{
  max-width:1000px;
  margin:auto;
  padding:24px;
}
.card{
  background:var(--paper);
  border:1px solid var(--border);
  border-radius:20px;
  padding:32px;
  box-shadow:0 12px 30px var(--shadow);
  margin-bottom:24px;
}
h1,h2,h3{margin-top:0}
p{line-height:1.7}
button{
  border:none;
  border-radius:12px;
  padding:12px 22px;
  cursor:pointer;
  font-size:15px;
  font-weight:600;
}
.btn-primary{background:var(--primary);color:white}
.btn-secondary{background:white;border:2px solid var(--border);color:var(--text)}
.btn-primary:hover,.btn-secondary:hover{transform:translateY(-1px)}
.option{
  width:100%;
  display:block;
  text-align:left;
  margin:12px 0;
  padding:16px;
  border:2px solid var(--border);
  border-radius:14px;
  background:white;
  cursor:pointer;
  font-size:15px;
}
.option:hover{border-color:var(--primary)}
.correct{border-color:var(--accent)!important;background:var(--accent-light)}
.wrong{border-color:var(--danger)!important;background:var(--danger-light)}
.hidden{display:none}
.progress{
  display:flex;
  justify-content:space-between;
  margin-bottom:16px;
  color:var(--muted);
  font-size:14px;
}
.feedback{
  margin-top:20px;
  padding:18px;
  border-radius:14px;
  line-height:1.7;
}
.good{background:var(--accent-light);border:1px solid #b7dfbb}
.bad{background:var(--danger-light);border:1px solid #efb2b2}
.nav-row{
  display:flex;
  justify-content:space-between;
  gap:12px;
  margin-top:20px;
  flex-wrap:wrap;
}
ul li{margin-bottom:10px}
.small{font-size:14px;color:var(--muted)}
.score-box{font-size:24px;font-weight:700;margin:16px 0}
.header{
  text-align:center;
  padding:20px 0 10px;
}
.header small{
  letter-spacing:2px;
  text-transform:uppercase;
  color:var(--muted);
  font-weight:600;
}
.header h1{
  font-size:42px;
  color:var(--primary);
}
.section-label{
  font-size:13px;
  text-transform:uppercase;
  letter-spacing:2px;
  color:var(--primary);
  font-weight:700;
  margin-bottom:10px;
}
</style>
</head>
<body>
<div class="container">

<div id="intro" class="card">
  <div class="header">
    <small>Interactive Learning Simulation</small>
    <h1>Core Accounting Challenge</h1>
  </div>

  <p><strong>Objective:</strong> Strengthen your understanding of core accounting by solving realistic business decisions involving financial statements, break-even analysis, budgeting, inventory, revenue recognition, and managerial accounting.</p>

  <div class="section-label">Learning Objectives</div>
  <ul>
    <li>Interpret major financial statements accurately</li>
    <li>Distinguish fixed, variable, and mixed costs</li>
    <li>Calculate contribution margin and break-even points</li>
    <li>Apply budgeting and variance analysis concepts</li>
    <li>Recognize proper revenue recognition timing</li>
    <li>Understand FIFO and inventory valuation principles</li>
    <li>Use relevant cost analysis for decisions</li>
  </ul>

  <p class="small">Each incorrect answer includes a teaching explanation. You may revisit earlier questions using the Back button without losing progress.</p>

  <div class="section-label">Choose a Section</div>
<div id="sectionButtons">
  <button class="btn-primary" onclick="startSection('Financial Statements')">Financial Statements</button>
  <button class="btn-primary" onclick="startSection('Cost Behavior + CVP')">Cost Behavior + CVP</button>
  <button class="btn-primary" onclick="startSection('Inventory + Revenue Recognition')">Inventory + Revenue Recognition</button>
  <button class="btn-primary" onclick="startSection('Budgeting + Decisions')">Budgeting + Decisions</button>
  <button class="btn-secondary" onclick="startFullGame()">Play Full Challenge (20+ Questions)</button>
</div>
</div>

<div id="game" class="hidden">
  <div class="card">
    <div class="progress">
      <div id="progress"></div>
      <div id="score"></div>
    </div>

    <div class="section-label" id="topicLabel">Question Topic</div>
    <h2 id="question"></h2>
    <div id="answers"></div>
    <div id="feedback"></div>

    <div class="nav-row">
      <button id="backBtn" class="btn-secondary" onclick="goBack()">← Back</button>
      <button id="nextBtn" class="btn-primary hidden" onclick="nextQuestion()">Next →</button>
    </div>
  </div>
</div>

<div id="results" class="hidden"></div>

</div>

<script>
const sections = {
"Financial Statements": [
{
label:"Financial Statements",
q:"Which financial statement shows revenues and expenses over a period of time?",
a:["Balance Sheet","Income Statement","Statement of Cash Flows","Bank Reconciliation"],
correct:1,
explain:"The Income Statement reports revenues, expenses, and net income over a period. The Balance Sheet shows financial position at a specific date."
},
{
label:"Financial Statements",
q:"Which statement reports assets, liabilities, and equity at a specific date?",
a:["Income Statement","Balance Sheet","Cash Budget","Variance Report"],
correct:1,
explain:"The Balance Sheet reports assets, liabilities, and shareholders' equity at a single point in time."
},
{
label:"Financial Statements",
q:"Accounts Payable is classified as:",
a:["Asset","Liability","Revenue","Expense"],
correct:1,
explain:"Accounts Payable is a liability because it represents amounts owed to suppliers."
}
],

"Cost Behavior + CVP": [
{
label:"Financial Statements",
q:"Which financial statement shows revenues and expenses over a period of time?",
a:["Balance Sheet","Income Statement","Statement of Cash Flows","Bank Reconciliation"],
correct:1,
explain:"The Income Statement reports revenues, expenses, and net income over a period. The Balance Sheet shows financial position at a specific date."
},
{
label:"Cost Behavior",
q:"Factory rent of $12,000 per month is best classified as:",
a:["Variable Cost","Fixed Cost","Mixed Cost","Direct Material"],
correct:1,
explain:"Factory rent remains constant regardless of production volume within the relevant range, so it is a fixed cost."
},
{
label:"Contribution Margin",
q:"Selling price is $50 and variable cost is $30. What is contribution margin per unit?",
a:["$20","$30","$50","$80"],
correct:0,
explain:"Contribution Margin per Unit = Selling Price − Variable Cost = $50 − $30 = $20."
},
{
label:"Break-Even Analysis",
q:"If fixed costs are $40,000 and contribution margin per unit is $20, break-even units are:",
a:["800","2,000","20,000","4,000"],
correct:1,
explain:"Break-even Units = Fixed Costs ÷ CM per Unit = $40,000 ÷ $20 = 2,000 units."
},
{
label:"Variance Analysis",
q:"A favorable materials price variance means:",
a:["Actual price > standard price","Actual price < standard price","Production stopped","Sales increased"],
correct:1,
explain:"Favorable means actual cost is lower than expected. If actual material price is lower than standard, the variance is favorable."
},
{
label:"Revenue Recognition",
q:"Revenue is usually recognized when:",
a:["Cash is always received","Performance obligation is satisfied","The invoice is printed","Management wants higher profit"],
correct:1,
explain:"Revenue is recognized when the performance obligation is satisfied under accrual accounting rules—not simply when cash is received."
},
{
label:"Inventory",
q:"FIFO inventory method means:",
a:["Newest inventory sold first","Oldest inventory sold first","Average cost only","No inventory tracking"],
correct:1,
explain:"FIFO stands for First-In, First-Out. The oldest inventory costs are assigned to cost of goods sold first."
},
{
label:"Managerial Decisions",
q:"A sunk cost should be considered in a special order decision.",
a:["True","False"],
correct:1,
explain:"False. Sunk costs have already occurred and cannot be changed, so they are irrelevant to future decisions."
},
{
label:"Balance Sheet",
q:"Which is included on the Balance Sheet?",
a:["Sales Revenue","Utilities Expense","Accounts Receivable","Commission Expense"],
correct:2,
explain:"Accounts Receivable is an asset shown on the Balance Sheet. Revenue and expenses belong on the Income Statement."
},
{
label:"Margin of Safety",
q:"If actual sales are 5,000 units and break-even sales are 4,000 units, the margin of safety is:",
a:["1,000 units","4,000 units","5,000 units","20% loss"],
correct:0,
explain:"Margin of Safety = Actual Sales − Break-even Sales = 5,000 − 4,000 = 1,000 units."
}
],

"Inventory + Revenue Recognition": [
{
label:"Inventory",
q:"FIFO inventory method means:",
a:["Newest inventory sold first","Oldest inventory sold first","Average cost only","No inventory tracking"],
correct:1,
explain:"FIFO stands for First-In, First-Out. The oldest inventory costs are assigned to cost of goods sold first."
},
{
label:"Revenue Recognition",
q:"Revenue is usually recognized when:",
a:["Cash is always received","Performance obligation is satisfied","The invoice is printed","Management wants higher profit"],
correct:1,
explain:"Revenue is recognized when the performance obligation is satisfied under accrual accounting rules—not simply when cash is received."
},
{
label:"Inventory",
q:"Ending inventory under FIFO during rising prices is generally:",
a:["Lower","Higher","Zero","Unchanged always"],
correct:1,
explain:"Under rising prices, FIFO leaves newer, higher-cost inventory in ending inventory, making ending inventory higher."
}
],

"Budgeting + Decisions": [
{
label:"Variance Analysis",
q:"A favorable materials price variance means:",
a:["Actual price > standard price","Actual price < standard price","Production stopped","Sales increased"],
correct:1,
explain:"Favorable means actual cost is lower than expected. If actual material price is lower than standard, the variance is favorable."
},
{
label:"Managerial Decisions",
q:"A sunk cost should be considered in a special order decision.",
a:["True","False"],
correct:1,
explain:"False. Sunk costs have already occurred and cannot be changed, so they are irrelevant to future decisions."
},
{
label:"Budgeting",
q:"Which budget is usually prepared first?",
a:["Cash Budget","Sales Budget","Production Budget","Capital Budget"],
correct:1,
explain:"The Sales Budget is prepared first because most other budgets depend on expected sales volume."
}
]
};

let questions = [];
let current = 0;
let score = 0;
let answered = Array(questions.length).fill(false);

function startSection(sectionName){
  questions = sections[sectionName];
  current = 0;
  score = 0;
  answered = Array(questions.length).fill(false);
  document.getElementById('intro').classList.add('hidden');
  document.getElementById('game').classList.remove('hidden');
  renderQuestion();
}

function startFullGame(){
  questions = Object.values(sections).flat();
  current = 0;
  score = 0;
  answered = Array(questions.length).fill(false);
  document.getElementById('intro').classList.add('hidden');
  document.getElementById('game').classList.remove('hidden');
  renderQuestion();
}

function startGame(){
  document.getElementById('intro').classList.add('hidden');
  document.getElementById('game').classList.remove('hidden');
  renderQuestion();
}

function renderQuestion(){
  const q = questions[current];
  document.getElementById('progress').innerText = `Question ${current+1} of ${questions.length}`;
  document.getElementById('score').innerText = `Score: ${score}/100`;
  document.getElementById('topicLabel').innerText = q.label;
  document.getElementById('question').innerText = q.q;

  const answers = document.getElementById('answers');
  const feedback = document.getElementById('feedback');
  const nextBtn = document.getElementById('nextBtn');
  const backBtn = document.getElementById('backBtn');

  answers.innerHTML='';
  feedback.innerHTML='';
  nextBtn.classList.add('hidden');
  backBtn.style.visibility = current === 0 ? 'hidden' : 'visible';

  q.a.forEach((text,index)=>{
    const btn=document.createElement('button');
    btn.className='option';
    btn.innerText=text;
    btn.onclick=()=>checkAnswer(index,btn);
    answers.appendChild(btn);
  });
}

function checkAnswer(selected,clickedBtn){
  const q = questions[current];
  const options = document.querySelectorAll('.option');
  options.forEach(btn=>btn.disabled=true);
  options[q.correct].classList.add('correct');

  let title='Correct';
  let style='good';

  if(selected===q.correct){
    if(!answered[current]) score += 10;
  } else {
    clickedBtn.classList.add('wrong');
    title='Review This Concept';
    style='bad';
  }

  answered[current] = true;

  document.getElementById('feedback').innerHTML = `
    <div class="feedback ${style}">
      <strong>${title}</strong><br><br>
      ${q.explain}
    </div>`;

  document.getElementById('score').innerText = `Score: ${score}/100`;
  document.getElementById('nextBtn').classList.remove('hidden');
}

function nextQuestion(){
  if(current < questions.length - 1){
    current++;
    renderQuestion();
  } else {
    showResults();
  }
}

function goBack(){
  if(current > 0){
    current--;
    renderQuestion();
  }
}

function showResults(){
  document.getElementById('game').classList.add('hidden');
  const results = document.getElementById('results');
  results.classList.remove('hidden');

  let grade='A';
  if(score < 90) grade='B';
  if(score < 70) grade='C';
  if(score < 50) grade='D';

  results.innerHTML = `
  <div class="card">
    <h1>Final Results</h1>
    <div class="score-box">Score: ${score} / 100</div>
    <h2>Grade: ${grade}</h2>
    <p>This simulation tested essential financial and managerial accounting principles with immediate teaching feedback to strengthen understanding—not just memorization.</p>

    <h3>Sources</h3>
    <p class="small">
    Weygandt, Kimmel & Kieso — Financial and Managerial Accounting<br>
    Horngren — Cost Accounting: A Managerial Emphasis<br>
    Garrison — Managerial Accounting<br>
    All scenarios created for educational purposes.
    </p>

    <button class="btn-primary" onclick="location.reload()">Play Again</button>
  </div>`;
}
</script>
</body>
</html>
